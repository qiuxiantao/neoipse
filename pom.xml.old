
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd"&gt;
    &lt;modelVersion&gt;4.0.0&lt;/modelVersion&gt;

    &lt;groupId&gt;cn.handyplus.neoipse&lt;/groupId&gt;
    &lt;artifactId&gt;neoipse&lt;/artifactId&gt;
    &lt;version&gt;1.0.0&lt;/version&gt;

    &lt;repositories&gt;
        &lt;repository&gt;
            &lt;id&gt;spigotmc-repo&lt;/id&gt;
            &lt;name&gt;SpigotMC Repository&lt;/name&gt;
            &lt;url&gt;https://hub.spigotmc.org/nexus/content/repositories/snapshots/&lt;/url&gt;
        &lt;/repository&gt;
        &lt;repository&gt;
            &lt;id&gt;handy-repository&lt;/id&gt;
            &lt;name&gt;handy-repository&lt;/name&gt;
            &lt;url&gt;https://nexus.handyplus.cn/repository/maven-public/&lt;/url&gt;
        &lt;/repository&gt;
        &lt;repository&gt;
            &lt;id&gt;placeholderapi&lt;/id&gt;
            &lt;name&gt;PlaceholderAPI Repository&lt;/name&gt;
            &lt;url&gt;https://repo.extendedclip.com/releases/&lt;/url&gt;
        &lt;/repository&gt;
    &lt;/repositories&gt;

    &lt;properties&gt;
        &lt;project.build.sourceEncoding&gt;UTF-8&lt;/project.build.sourceEncoding&gt;
        &lt;java.version&gt;17&lt;/java.version&gt;
        &lt;maven.compiler.source&gt;${java.version}&lt;/maven.compiler.source&gt;
        &lt;maven.compiler.target&gt;${java.version}&lt;/maven.compiler.target&gt;
        &lt;maven.compiler.release&gt;${java.version}&lt;/maven.compiler.release&gt;
        &lt;HandyLib.version&gt;3.7.8&lt;/HandyLib.version&gt;
        &lt;ip2region.version&gt;3.1.1&lt;/ip2region.version&gt;
        &lt;placeholderapi.version&gt;2.11.7&lt;/placeholderapi.version&gt;
        &lt;junit.version&gt;5.13.2&lt;/junit.version&gt;
        &lt;spigot-api.version&gt;26.1.2-R0.1-SNAPSHOT&lt;/spigot-api.version&gt;
        &lt;lombok.version&gt;1.18.30&lt;/lombok.version&gt;
    &lt;/properties&gt;

    &lt;dependencies&gt;
        &lt;dependency&gt;
            &lt;groupId&gt;org.spigotmc&lt;/groupId&gt;
            &lt;artifactId&gt;spigot-api&lt;/artifactId&gt;
            &lt;version&gt;${spigot-api.version}&lt;/version&gt;
            &lt;scope&gt;provided&lt;/scope&gt;
        &lt;/dependency&gt;
        &lt;dependency&gt;
            &lt;groupId&gt;cn.handyplus.lib&lt;/groupId&gt;
            &lt;artifactId&gt;HandyLib&lt;/artifactId&gt;
            &lt;version&gt;${HandyLib.version}&lt;/version&gt;
            &lt;optional&gt;true&lt;/optional&gt;
        &lt;/dependency&gt;
        &lt;dependency&gt;
            &lt;groupId&gt;org.lionsoul&lt;/groupId&gt;
            &lt;artifactId&gt;ip2region&lt;/artifactId&gt;
            &lt;version&gt;${ip2region.version}&lt;/version&gt;
            &lt;optional&gt;true&lt;/optional&gt;
        &lt;/dependency&gt;
        &lt;dependency&gt;
            &lt;groupId&gt;me.clip&lt;/groupId&gt;
            &lt;artifactId&gt;placeholderapi&lt;/artifactId&gt;
            &lt;version&gt;${placeholderapi.version}&lt;/version&gt;
            &lt;scope&gt;provided&lt;/scope&gt;
        &lt;/dependency&gt;
        &lt;dependency&gt;
            &lt;groupId&gt;org.projectlombok&lt;/groupId&gt;
            &lt;artifactId&gt;lombok&lt;/artifactId&gt;
            &lt;version&gt;${lombok.version}&lt;/version&gt;
            &lt;scope&gt;provided&lt;/scope&gt;
        &lt;/dependency&gt;
        &lt;dependency&gt;
            &lt;groupId&gt;org.junit.jupiter&lt;/groupId&gt;
            &lt;artifactId&gt;junit-jupiter-engine&lt;/artifactId&gt;
            &lt;version&gt;${junit.version}&lt;/version&gt;
            &lt;scope&gt;test&lt;/scope&gt;
        &lt;/dependency&gt;
    &lt;/dependencies&gt;

    &lt;build&gt;
        &lt;plugins&gt;
            &lt;plugin&gt;
                &lt;groupId&gt;org.apache.maven.plugins&lt;/groupId&gt;
                &lt;artifactId&gt;maven-compiler-plugin&lt;/artifactId&gt;
                &lt;version&gt;3.15.0&lt;/version&gt;
                &lt;configuration&gt;
                    &lt;source&gt;${java.version}&lt;/source&gt;
                    &lt;target&gt;${java.version}&lt;/target&gt;
                    &lt;release&gt;${java.version}&lt;/release&gt;
                    &lt;annotationProcessorPaths&gt;
                        &lt;path&gt;
                            &lt;groupId&gt;org.projectlombok&lt;/groupId&gt;
                            &lt;artifactId&gt;lombok&lt;/artifactId&gt;
                            &lt;version&gt;${lombok.version}&lt;/version&gt;
                        &lt;/path&gt;
                    &lt;/annotationProcessorPaths&gt;
                    &lt;compilerArgs&gt;
                        &lt;arg&gt;-Xlint:-options&lt;/arg&gt;
                        &lt;arg&gt;-Xlint:-removal&lt;/arg&gt;
                    &lt;/compilerArgs&gt;
                &lt;/configuration&gt;
            &lt;/plugin&gt;
            &lt;plugin&gt;
                &lt;groupId&gt;org.apache.maven.plugins&lt;/groupId&gt;
                &lt;artifactId&gt;maven-shade-plugin&lt;/artifactId&gt;
                &lt;version&gt;3.6.0&lt;/version&gt;
                &lt;configuration&gt;
                    &lt;createDependencyReducedPom&gt;false&lt;/createDependencyReducedPom&gt;
                    &lt;artifactSet&gt;
                        &lt;includes&gt;
                            &lt;include&gt;cn.handyplus.lib:*:*:*&lt;/include&gt;
                            &lt;include&gt;org.lionsoul:*:*:*&lt;/include&gt;
                        &lt;/includes&gt;
                    &lt;/artifactSet&gt;
                    &lt;relocations&gt;
                        &lt;relocation&gt;
                            &lt;pattern&gt;cn.handyplus.lib&lt;/pattern&gt;
                            &lt;shadedPattern&gt;cn.handyplus.neoipse.lib&lt;/shadedPattern&gt;
                        &lt;/relocation&gt;
                        &lt;relocation&gt;
                            &lt;pattern&gt;org.lionsoul&lt;/pattern&gt;
                            &lt;shadedPattern&gt;cn.handyplus.neoipse.lionsoul&lt;/shadedPattern&gt;
                        &lt;/relocation&gt;
                    &lt;/relocations&gt;
                &lt;/configuration&gt;
                &lt;executions&gt;
                    &lt;execution&gt;
                        &lt;phase&gt;package&lt;/phase&gt;
                        &lt;goals&gt;
                            &lt;goal&gt;shade&lt;/goal&gt;
                        &lt;/goals&gt;
                        &lt;configuration&gt;
                            &lt;filters&gt;
                                &lt;filter&gt;
                                    &lt;artifact&gt;*:*&lt;/artifact&gt;
                                    &lt;excludes&gt;
                                        &lt;exclude&gt;META-INF/MANIFEST.MF&lt;/exclude&gt;
                                    &lt;/excludes&gt;
                                &lt;/filter&gt;
                            &lt;/filters&gt;
                        &lt;/configuration&gt;
                    &lt;/execution&gt;
                &lt;/executions&gt;
            &lt;/plugin&gt;
        &lt;/plugins&gt;
    &lt;/build&gt;

&lt;/project&gt;
